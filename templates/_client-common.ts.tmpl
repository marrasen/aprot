{{define "react-context"}}
// React Context
const ApiClientContext = createContext<ApiClient | null>(null);

export const ApiClientProvider = ApiClientContext.Provider;

export function useApiClient(): ApiClient {
    const client = useContext(ApiClientContext);
    if (!client) {
        throw new Error('useApiClient must be used within an ApiClientProvider');
    }
    return client;
}

// Connection state hook
export function useConnectionState(): ConnectionState {
    const client = useApiClient();
    const [state, setState] = useState<ConnectionState>(client.getState());

    useEffect(() => {
        return client.onStateChange(setState);
    }, [client]);

    return state;
}

// Connection hook (convenience wrapper)
export function useConnection(): { isConnected: boolean; state: ConnectionState } {
    const state = useConnectionState();
    return { isConnected: state === 'connected', state };
}

// Loading state hook
export function useIsLoading(): boolean {
    const client = useApiClient();
    const [loading, setLoading] = useState<boolean>(client.getLoadingCount() > 0);

    useEffect(() => {
        return client.onLoadingChange((count) => setLoading(count > 0));
    }, [client]);

    return loading;
}
{{end}}

{{define "react-hook-types"}}
/**
 * Options for {@link useQuery} hooks.
 */
export interface UseQueryOptions {
    /**
     * When `false`, the query will not execute. Useful for conditional fetching
     * (e.g., wait until an ID is available). Defaults to `true`.
     */
    enabled?: boolean;
    /**
     * Polling interval in milliseconds. Only applies in non-subscription
     * (one-shot) mode. When set, the query re-fetches on this interval in
     * addition to the initial fetch. Set to `0` or omit to disable.
     */
    refetchInterval?: number;
    /**
     * When `true` (default), multiple hooks subscribing to the same method
     * and parameters share a single server subscription. The first hook
     * creates the subscription; subsequent hooks receive data instantly from
     * the cache. Set to `false` to create an independent subscription.
     *
     * Only applies in subscription mode (server-driven refresh).
     * Override the global default with {@link setQueryCacheEnabled}.
     */
    cache?: boolean;
    /** @internal Subscription metadata for auto-refresh. */
    _subscribe?: { method: string; params: unknown[] };
}

/**
 * Return value of {@link useQuery} hooks (e.g., `useListUsers()`).
 *
 * ## Subscription mode (default for generated hooks)
 *
 * Generated query hooks like `useListUsers()` use server-driven subscriptions.
 * The server re-executes the query handler whenever a `TriggerRefresh` fires
 * for a matching key and pushes the new result — the client never polls.
 *
 * ## Cancellation
 *
 * The underlying request carries an `AbortSignal` tied to the React effect
 * lifecycle. The signal is aborted (and the Go handler's `context.Context`
 * is canceled) when:
 *
 * - The component unmounts.
 * - The hook's dependency parameters change (the old request is aborted
 *   before the new one starts).
 * - React Strict Mode re-runs effects (the first effect is cleaned up, then
 *   a second one starts — this is safe and expected).
 *
 * @typeParam TRes - The response type returned by the query.
 */
export interface UseQueryResult<TRes> {
    /** The last successful response, or `null` if no data has been fetched yet. */
    data: TRes | null;
    /** The error from the last fetch attempt, or `null`. Cleared on the next successful fetch. */
    error: Error | null;
    /** `true` while a fetch or subscription update is in progress. */
    isLoading: boolean;
    /**
     * Manually trigger a re-fetch. In subscription mode this is rarely needed
     * since the server pushes updates automatically.
     */
    refetch: () => void;
    /**
     * Run an async action (e.g., a mutation), then automatically re-fetch
     * this query's data. Useful for fire-and-forget mutations that should
     * refresh the query on completion:
     *
     * ```ts
     * const { mutate } = useListUsers();
     * // Run createUser, then refetch the user list:
     * mutate(createUser(client, { name: 'Alice' }));
     * ```
     *
     * Sets `isLoading` to `true` for the duration. If the action rejects,
     * the error is captured in the `error` field and the refetch is skipped.
     *
     * **Note:** This is different from `useMutation` — it is a convenience
     * for triggering a side effect and refreshing the query in one call.
     */
    mutate: (action: Promise<unknown> | (() => Promise<unknown>)) => Promise<void>;
}

/**
 * Options for mutation hooks (e.g., `useCreateUserMutation()`).
 */
export interface UseMutationOptions {
    /**
     * Called when the server sends progress updates during a long-running
     * handler. The handler reports progress via `aprot.Progress(ctx).Update(...)`.
     */
    onProgress?: (current: number, total: number, message: string) => void;
}

/**
 * Return value of mutation hooks (e.g., `useCreateUserMutation()`).
 *
 * Mutations are imperative — nothing happens until you call `mutate()`.
 * Each call creates a new `AbortController`; calling `mutate()` again
 * while a previous call is in-flight aborts the previous request (and
 * cancels the Go handler's `context.Context`).
 *
 * Errors are captured in the `error` field and are **not** re-thrown.
 * You do not need try/catch around `mutate()` calls.
 *
 * @typeParam TParams - Tuple of the mutation's parameter types.
 * @typeParam TRes - The response type returned by the mutation.
 */
export interface UseMutationResult<TParams extends unknown[], TRes> {
    /**
     * Call the mutation. Returns a `Promise` that resolves with the server
     * response on success, or `undefined` on error (check the `error` field).
     *
     * Calling `mutate()` again while a previous call is in-flight aborts
     * the previous request.
     */
    mutate: (...params: TParams) => Promise<TRes>;
    /** The last successful response, or `null` if the mutation has not been called yet. */
    data: TRes | null;
    /** The error from the last `mutate()` call, or `null`. Cleared at the start of each new call. */
    error: Error | null;
    /** `true` while a `mutate()` call is in-flight. */
    isLoading: boolean;
    /** Reset `data`, `error`, and `isLoading` to their initial values. */
    reset: () => void;
    /** Abort the in-flight mutation request. Cancels the Go handler's context. */
    cancel: () => void;
}

/**
 * Return value of push event hooks (e.g., `useUserCreatedEvent()`).
 *
 * Subscribes to a server push event for the lifetime of the component.
 * Events are accumulated in the `events` array (up to `maxEvents`,
 * default 100).
 *
 * @typeParam T - The push event data type.
 */
export interface UsePushResult<T> {
    /** The most recent event, or `null` if none received yet. */
    lastEvent: T | null;
    /** All received events (oldest first), capped at `maxEvents`. */
    events: T[];
    /** Clear `lastEvent` and the `events` array. */
    clear: () => void;
}
