  "components": {
    "schemas": {
      "CreateTodoRequest": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "maxLength": 1000
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "required": [
          "description",
          "priority",
          "title"
        ]
      },
      "CreateUserResponse": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "id",
          "name"
        ]
      },
      "GetDashboardResponse": {
        "type": "object",
        "properties": {
          "featuredUsers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "tagsById": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Tag"
            }
          },
          "usersByRole": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "required": [
          "featuredUsers",
          "tagsById",
          "usersByRole"
        ]
      },
      "GetTaskResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "created",
              "running",
              "completed",
              "failed"
            ]
          }
        },
        "required": [
          "id",
          "name",
          "status"
        ]
      },
      "GetUserResponse": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "id",
          "name"
        ]
      },
      "ListTodosResponse": {
        "type": "object",
        "properties": {
          "todos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Todo"
            }
          },
          "total": {
            "type": "integer"
          }
        },
        "required": [
          "todos",
          "total"
        ]
      },
      "ListUsersResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          }
        },
        "required": [
          "users"
        ]
      },
      "ProcessBatchResponse": {
        "type": "object",
        "properties": {
          "processed": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "processed",
          "results"
        ]
      },
      "StartSharedWorkResponse": {
        "type": "object",
        "properties": {
          "completed": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StepResult"
            }
          },
          "totalDuration": {
            "type": "integer"
          },
          "totalSteps": {
            "type": "integer"
          }
        },
        "required": [
          "completed",
          "results",
          "totalDuration",
          "totalSteps"
        ]
      },
      "StepResult": {
        "type": "object",
        "properties": {
          "duration": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "step": {
            "type": "string"
          }
        },
        "required": [
          "duration",
          "step"
        ]
      },
      "SystemNotificationEvent": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "level",
          "message"
        ]
      },
      "Tag": {
        "type": "object",
        "properties": {
          "color": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "color",
          "id",
          "name"
        ]
      },
      "Todo": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "description",
          "done",
          "id",
          "priority",
          "title"
        ]
      },
      "UpdateTodoRequest": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "maxLength": 1000
          },
          "done": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "id",
          "name"
        ]
      }
    }
  }
}